# Environment Template (copy to .env for local usage)

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/postly?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379

# Server
PORT=3000
NODE_ENV="development"

# Security
# 32-byte (256-bit) encryption key for AES-256 tokens and AI Keys
ENCRYPTION_KEY="replace_me_with_a_32_byte_secure_string_here_!"

# JWT Auth
JWT_ACCESS_SECRET="your_access_token_secret_min_32_chars"
JWT_REFRESH_SECRET="your_refresh_token_secret_min_32_chars"

# Fallback AI Platform Keys
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."

# Telegram
TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrsTUVwxyz..."
# In production, specify the webhook domain:
# TELEGRAM_WEBHOOK_URL="https://your-api.domain.com"
