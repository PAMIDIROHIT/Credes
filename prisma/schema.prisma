// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  name             String
  email            String   @unique
  password_hash    String
  bio              String?
  default_tone     String?  @default("professional")
  default_language String?  @default("en")
  created_at       DateTime @default(now())

  // Relations
  social_accounts SocialAccount[]
  ai_keys         AiKey?
  posts           Post[]

  @@map("users")
}

model SocialAccount {
  id                 String   @id @default(uuid())
  user_id            String
  platform           String   // twitter, linkedin, instagram, threads
  access_token_enc   String
  refresh_token_enc  String?
  handle             String?
  connected_at       DateTime @default(now())

  user               User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("social_accounts")
}

model AiKey {
  id                 String   @id @default(uuid())
  user_id            String   @unique
  openai_key_enc     String?
  anthropic_key_enc  String?
  updated_at         DateTime @updatedAt

  user               User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("ai_keys")
}

model Post {
  id               String   @id @default(uuid())
  user_id          String
  idea             String   // max 500 chars (handled in app validation)
  post_type        String   // announcement, thread, story, etc.
  tone             String
  language         String   @default("en")
  model_used       String   // openai or anthropic
  created_at       DateTime @default(now())
  publish_at       DateTime?
  status           String   @default("queued") // queued, processing, published, failed, cancelled

  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  platform_posts   PlatformPost[]

  @@map("posts")
}

model PlatformPost {
  id               String   @id @default(uuid())
  post_id          String
  platform         String   // twitter, linkedin, instagram, threads
  content          String   @db.Text
  status           String   @default("queued") // queued, processing, published, failed, cancelled
  published_at     DateTime?
  error_message    String?  @db.Text
  attempts         Int      @default(0)

  post             Post     @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@map("platform_posts")
}
